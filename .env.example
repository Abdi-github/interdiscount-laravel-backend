APP_NAME="Interdiscount Clone"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Zurich
APP_URL=http://localhost:4004
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_CH
APP_SUPPORTED_LOCALES=de,en,fr,it

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (MySQL) ──
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=interdiscount
DB_USERNAME=interdiscount
DB_PASSWORD=interdiscount_secret

# ── Session ──
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Queue ──
QUEUE_CONNECTION=redis

# ── Cache ──
CACHE_STORE=redis

# ── Redis ──
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (Mailpit) ──
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@interdiscount-clone.ch
MAIL_FROM_NAME="Interdiscount Clone"

# ── Search (Meilisearch) ──
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey

# ── Cloudinary ──
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stripe ──
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── Sanctum ──
SANCTUM_STATEFUL_DOMAINS=localhost:5174

# ── Horizon ──
HORIZON_PREFIX=interdiscount_horizon:

# ── Vite ──
VITE_APP_NAME="${APP_NAME}"
