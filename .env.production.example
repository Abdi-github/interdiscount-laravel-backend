APP_NAME="Interdiscount Clone"
APP_ENV=production
APP_KEY=base64:YOUR_LARAVEL_APP_KEY_HERE
APP_DEBUG=false
APP_TIMEZONE=Europe/Zurich
APP_URL=https://interdiscount.swiftapp.ch
FRONTEND_URL=https://interdiscount-react.swiftapp.ch
ADMIN_URL=https://interdiscount-admin.swiftapp.ch
APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_CH
APP_SUPPORTED_LOCALES=de,en,fr,it

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=interdiscount_prod
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password_here

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@interdiscount.swiftapp.ch
MAIL_FROM_NAME="Interdiscount Clone"

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=your_meilisearch_key

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=interdiscount

STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_API_VERSION=2024-12-18.acacia

SANCTUM_STATEFUL_DOMAINS=interdiscount-react.swiftapp.ch,interdiscount-admin.swiftapp.ch
SESSION_DOMAIN=.swiftapp.ch

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

HORIZON_PREFIX=interdiscount_horizon:
VITE_APP_NAME="${APP_NAME}"
